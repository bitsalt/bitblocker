# Build-context excludes for `docker build`. Mirrors .gitignore plus
# repo metadata that the Docker build never needs.

.git/
.github/
.claude/
docs/
*.md

bin/
coverage.out
coverage.html
*.test
*.out

# Example/template config never belongs in the image; the daemon reads
# its config from an operator-supplied bind mount (see Dockerfile).
config.example.yaml
