      "Bash(git stash list)",
      "Bash(git stash show*)",
      "Bash(git fetch*)",
      "Bash(git pull --ff-only*)",

      "Bash(git add :*)",
      "Bash(git add -p*)",
      "Bash(git restore --staged*)",
      "Bash(git commit -m *)",
      "Bash(git commit -F *)",
      "Bash(git switch *)",
