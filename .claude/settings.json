      "Bash(git push * :*)",

      "Bash(git reset --hard*)",
      "Bash(git reset --merge*)",
      "Bash(git reset --keep*)",
      "Bash(git checkout -- *)",
      "Bash(git checkout .)",
      "Bash(git restore .)",
      "Bash(git restore --worktree .)",
      "Bash(git restore --worktree --staged*)",
      "Bash(git clean -f*)",
      "Bash(git clean -d*)",
      "Bash(git clean -x*)",
      "Bash(git clean -fd*)",
      "Bash(git clean -fx*)",

      "Bash(git branch -D*)",
      "Bash(git branch -d*)",
      "Bash(git branch --delete*)",
      "Bash(git branch -m main*)",
      "Bash(git branch -m master*)",
      "Bash(git branch -M main*)",
      "Bash(git branch -M master*)",

      "Bash(git rebase -i*)",
      "Bash(git rebase --interactive*)",
      "Bash(git commit --amend*)",
      "Bash(git commit --no-verify*)",
      "Bash(git commit --no-gpg-sign*)",
      "Bash(git commit -c commit.gpgsign=false*)",
      "Bash(git -c commit.gpgsign=false commit*)",

      "Bash(git config*)",
      "Bash(git filter-branch*)",
      "Bash(git update-ref -d*)",
      "Bash(git tag -d*)",
      "Bash(git tag --delete*)",
      "Bash(git push * --tags --force*)",

      "Bash(gh pr merge *)",
      "Bash(gh pr close *)",
      "Bash(gh pr reopen *)",
      "Bash(gh issue close *)",
      "Bash(gh issue delete *)",
      "Bash(gh repo delete *)",
