#!/usr/bin/env bash
# BitBlocker pre-commit hook. Activate once per clone with:
#   git config core.hooksPath scripts/git-hooks
#
# Runs gofmt + goimports (via golangci-lint fmt) and the full lint
# suite. Tests are not run here; that's CI's job — pre-commit is for
# fast feedback on the commit itself.
#
# Skip with `git commit --no-verify` when you genuinely need to
# (rare). Do not skip habitually.

set -euo pipefail

if ! command -v golangci-lint >/dev/null 2>&1; then
  echo "pre-commit: golangci-lint not found on PATH" >&2
  echo "install with: go install github.com/golangci/golangci-lint/v2/cmd/golangci-lint@latest" >&2
  exit 1
fi

echo "pre-commit: gofmt + goimports"
golangci-lint fmt --diff ./...

echo "pre-commit: golangci-lint run"
golangci-lint run ./...
